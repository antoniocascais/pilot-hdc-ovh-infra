# Copy to sensitive.yml and fill in values
ssh_key_path: /tmp/ansible.ovh.ssh
target_ssh_port: 53729
ssh_port: 22  # optional override for connection; remove after hardening

nginx_hosts:
  dev:
    ip: 1.2.3.4
    k8s_nodes:
      - 10.0.0.100
      - 10.0.0.101
  prod:
    ip: 5.6.7.8
    k8s_nodes: []  # populate when prod K8s is ready

nfs_hosts:
  dev:
    ip: 10.0.0.x  # private IP from: terraform output nfs_addresses

freeipa_hosts:
  dev:
    ip: 10.0.0.x  # private IP from: terraform output freeipa_addresses

# FreeIPA secrets
freeipa_admin_password: changeme
freeipa_ds_password: changeme

guacamole_hosts:
  dev:
    workspacetest:
      ip: 10.0.0.x  # private IP from: terraform output guacamole_addresses

admin_email: admin@my.domain

# Argo CD bootstrap
argocd_kubeconfig: /path/to/kubeconfig
gitops_repo_path: /path/to/gitops/repo
