services:
  freeipa:
    image: freeipa/freeipa-server:rocky-9-4.12.2
    restart: unless-stopped
    hostname: {{ freeipa_hostname }}
    environment:
      IPA_SERVER_HOSTNAME: {{ freeipa_hostname }}
      TZ: "UTC"
    tty: true
    stdin_open: true
    cgroup: host
    cap_add:
      - NET_ADMIN
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - /sys/fs/cgroup:/sys/fs/cgroup:rw
      - {{ freeipa_data_dir }}:/data
    sysctls:
      - net.ipv6.conf.all.disable_ipv6=0
      - net.ipv6.conf.lo.disable_ipv6=0
    shm_size: 256m
    command:
      - -U
      - --domain={{ freeipa_domain }}
      - --realm={{ freeipa_realm }}
      - --ds-password={{ freeipa_ds_password[freeipa_env] }}
      - --admin-password={{ freeipa_admin_password[freeipa_env] }}
      - --no-host-dns
      - --skip-mem-check
      - --unattended
    ports:
      - "5353:53/udp"
      - "5353:53"
      - "80:80"
      - "443:443"
      - "389:389"
      - "636:636"
      - "88:88"
      - "464:464"
      - "88:88/udp"
      - "464:464/udp"
      - "123:123/udp"
      - "7389:7389"
      - "9443:9443"
      - "9444:9444"
      - "9445:9445"
